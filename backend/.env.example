# =============================================================================
# LLM Configuration — Three-Model Architecture
# =============================================================================

# PRIMARY (required for full coaching features)
# Claude Sonnet 4.6  →  ~90% of conversations (routine coaching)
# Claude Opus 4.6    →  ~10% of conversations (complex decisions, deep reflection)
# Claude Haiku 4.5   →  async background classification (escalation, goal extraction)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# FALLBACK (optional — used only if ANTHROPIC_API_KEY is not set)
# Falls back to GPT-4 flat (no tiered model selection)
OPENAI_API_KEY=sk-your-openai-key-here

# =============================================================================
# Auth Configuration
# =============================================================================

JWT_SECRET=your-secret-key-here-min-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=com.pathvana.ascendra://auth-callback

# =============================================================================
# Cache / Idempotency (Redis recommended in production)
# =============================================================================

CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
IDEMP_TTL_SECONDS=1200
LOCK_TTL_SECONDS=120
FOLLOWER_WAIT_SECONDS_CHAT=12
FOLLOWER_WAIT_SECONDS_STREAM=120
